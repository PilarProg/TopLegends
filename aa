<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HP Clan | Stumble Guys Competitivo</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        /* --- CONFIGURAÇÕES GERAIS --- */
        :root {
            --primary: #E50914;
            --primary-glow: rgba(229, 9, 20, 0.6);
            --bg-dark: #0D0D0D;
            --bg-card: rgba(20, 20, 20, 0.65);
            --text-light: #FFFFFF;
            --text-gray: #A0A0A0;
            --border-glass: rgba(255, 255, 255, 0.05);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
            scroll-behavior: smooth;
        }

        body {
            background-color: var(--bg-dark);
            color: var(--text-light);
            overflow-x: hidden;
            position: relative;
        }

        /* Canvas de Partículas */
        #particles-canvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 1;
            pointer-events: none;
        }

        .container {
            width: 100%;
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
            position: relative;
            z-index: 2;
        }

        /* --- ANIMAÇÃO DE REVELAÇÃO (Scroll Reveal) --- */
        .reveal {
            opacity: 0;
            transform: translateY(40px);
            transition: all 0.8s ease;
        }

        .reveal.active {
            opacity: 1;
            transform: translateY(0);
        }

        /* --- CABEÇALHO & NAVBAR --- */
        header {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            background: rgba(13, 13, 13, 0.8);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid var(--border-glass);
            z-index: 1000;
            transition: all 0.3s ease;
        }

        header.scrolled {
            padding: 5px 0;
            background: rgba(5, 5, 5, 0.95);
            border-bottom: 1px solid var(--primary);
            box-shadow: 0 5px 20px rgba(229, 9, 20, 0.2);
        }

        .nav-wrapper {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 0;
        }

        .brand {
            display: flex;
            flex-direction: column;
        }

        .logo {
            font-size: 2rem;
            font-weight: 800;
            color: var(--text-light);
            letter-spacing: 2px;
            line-height: 1;
        }

        .logo span {
            color: var(--primary);
            text-shadow: 0 0 10px var(--primary-glow);
        }

        .sub-logo {
            font-size: 0.65rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-gray);
            font-weight: 600;
        }

        .nav-menu {
            display: flex;
            list-style: none;
            gap: 25px;
            align-items: center;
        }

        .nav-item a {
            color: var(--text-light);
            text-decoration: none;
            font-weight: 600;
            font-size: 0.9rem;
            text-transform: uppercase;
            transition: color 0.3s ease;
            position: relative;
        }

        .nav-item a::after {
            content: '';
            position: absolute;
            bottom: -5px;
            left: 0;
            width: 0;
            height: 2px;
            background-color: var(--primary);
            transition: width 0.3s ease;
            box-shadow: 0 0 8px var(--primary);
        }

        .nav-item a:hover::after {
            width: 100%;
        }

        .nav-item a:hover {
            color: var(--primary);
        }

        /* Botões */
        .btn-primary {
            background: var(--primary);
            color: var(--text-light);
            padding: 10px 24px;
            border: none;
            border-radius: 4px;
            font-weight: 700;
            text-transform: uppercase;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 0 15px var(--primary-glow);
            text-decoration: none;
            display: inline-block;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 0 25px var(--primary);
            background: #ff1c27;
        }

        .btn-yt {
            background: #FF0000;
            box-shadow: 0 0 15px rgba(255, 0, 0, 0.3);
            font-size: 0.85rem;
            padding: 8px 16px;
            margin-top: 10px;
        }
        .btn-yt:hover {
            background: #cc0000;
            box-shadow: 0 0 25px #FF0000;
        }

        /* Menu Mobile */
        .menu-toggle {
            display: none;
            flex-direction: column;
            gap: 5px;
            cursor: pointer;
        }

        .menu-toggle span {
            width: 25px;
            height: 3px;
            background-color: var(--text-light);
            transition: 0.3s;
        }

        /* --- SESSÃO INICIAL (HERO) --- */
        #inicio {
            min-height: 100vh;
            display: flex;
            align-items: center;
            padding-top: 120px;
            background: radial-gradient(circle at 50% 50%, rgba(229, 9, 20, 0.1) 0%, transparent 70%);
        }

        .hero-layout {
            text-align: center;
            max-width: 900px;
            margin: 0 auto;
        }

        .hero-layout h1 {
            font-size: 4rem;
            font-weight: 800;
            line-height: 1.1;
            margin-bottom: 25px;
            text-transform: uppercase;
            letter-spacing: -1px;
        }

        .hero-layout h1 span {
            color: var(--primary);
            text-shadow: 0 0 20px var(--primary-glow);
        }

        .hero-layout p {
            color: var(--text-gray);
            font-size: 1.2rem;
            line-height: 1.6;
            margin-bottom: 40px;
        }

        /* --- SESSÃO REQUISITOS --- */
        section {
            padding: 100px 0;
        }

        .section-title {
            font-size: 2.5rem;
            font-weight: 800;
            text-transform: uppercase;
            text-align: center;
            margin-bottom: 60px;
            position: relative;
        }

        .section-title span {
            color: var(--primary);
        }

        .section-title::after {
            content: '';
            position: absolute;
            bottom: -15px;
            left: 50%;
            transform: translateX(-50%);
            width: 80px;
            height: 4px;
            background-color: var(--primary);
            box-shadow: 0 0 10px var(--primary);
        }

        .req-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 25px;
            margin-bottom: 50px;
        }

        .card {
            background: var(--bg-card);
            backdrop-filter: blur(12px);
            border: 1px solid var(--border-glass);
            border-radius: 8px;
            padding: 40px 30px;
            text-align: center;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        .card:hover {
            transform: translateY(-10px);
            border-color: var(--primary);
            box-shadow: 0 10px 30px rgba(229, 9, 20, 0.2);
        }

        .card-icon {
            font-size: 2.5rem;
            color: var(--primary);
            margin-bottom: 20px;
            display: inline-block;
        }

        .card h3 {
            font-size: 1.1rem;
            font-weight: 700;
            text-transform: uppercase;
        }

        .warning-box {
            background: rgba(229, 9, 20, 0.1);
            border-left: 5px solid var(--primary);
            padding: 20px;
            border-radius: 0 8px 8px 0;
            text-align: center;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        /* --- QUEM SOMOS --- */
        .about-content {
            background: var(--bg-card);
            border: 1px solid var(--border-glass);
            border-radius: 12px;
            padding: 50px;
            backdrop-filter: blur(10px);
        }

        .about-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 40px;
            margin-top: 30px;
            margin-bottom: 45px;
            max-width: 600px;
            margin-left: auto;
            margin-right: auto;
        }

        .about-block {
            background: rgba(0, 0, 0, 0.4);
            padding: 30px;
            border-radius: 8px;
            text-align: center;
        }

        .about-block.focus-block { border-top: 3px solid #00E676; }

        .about-block h4 {
            font-size: 1.2rem;
            text-transform: uppercase;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .about-block ul { list-style: none; }
        .about-block ul li {
            margin-bottom: 10px;
            color: var(--text-gray);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .about-quote {
            text-align: center;
            font-size: 1.25rem;
            font-style: italic;
            border-top: 1px solid var(--border-glass);
            padding-top: 30px;
        }

        .about-quote span { color: var(--primary); font-weight: 600; }

        /* --- NOVA SEÇÃO: O QUE NÃO ESTÁ DISPONÍVEL --- */
        .unavailable-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 25px;
            max-width: 800px;
            margin: 0 auto;
        }

        .unavailable-card {
            background: rgba(229, 9, 20, 0.03);
            border: 1px solid rgba(229, 9, 20, 0.15);
            border-radius: 12px;
            padding: 40px 30px;
            text-align: center;
            backdrop-filter: blur(10px);
            transition: all 0.3s ease;
        }

        .unavailable-card:hover {
            border-color: var(--primary);
            box-shadow: 0 0 20px rgba(229, 9, 20, 0.15);
            transform: translateY(-3px);
        }

        .unavailable-card i {
            font-size: 3rem;
            color: var(--primary);
            margin-bottom: 20px;
            filter: drop-shadow(0 0 10px var(--primary-glow));
        }

        .unavailable-card h3 {
            font-size: 1.4rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-light);
            margin-bottom: 10px;
        }

        .unavailable-card p {
            color: var(--text-gray);
            font-size: 0.95rem;
        }

        /* --- SESSÃO CANAIS (NO FINAL) --- */
        .channels-container {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 25px;
            max-width: 700px;
            margin: 0 auto;
        }

        .channel-card {
            background: var(--bg-card);
            border: 1px solid var(--border-glass);
            border-radius: 8px;
            padding: 30px;
            display: flex;
            flex-direction: column;
            align-items: center;
            backdrop-filter: blur(10px);
            transition: all 0.3s ease;
        }

        .channel-card:hover {
            border-color: #FF0000;
            box-shadow: 0 5px 25px rgba(255, 0, 0, 0.2);
            transform: translateY(-3px);
        }

        .channel-card i {
            font-size: 2.5rem;
            color: #FF0000;
            margin-bottom: 15px;
            filter: drop-shadow(0 0 8px rgba(255, 0, 0, 0.4));
        }

        .channel-card h3 {
            font-size: 1.1rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 5px;
        }

        /* --- DISCORD --- */
        #discord { text-align: center; }
        .discord-box {
            background: linear-gradient(135deg, var(--bg-card), rgba(114, 137, 218, 0.1));
            border: 1px solid rgba(114, 137, 218, 0.2);
            border-radius: 16px;
            padding: 60px 40px;
            max-width: 800px;
            margin: 0 auto;
            backdrop-filter: blur(10px);
        }

        .discord-box i.main-disc-icon {
            font-size: 4.5rem;
            color: #7289DA;
            margin-bottom: 25px;
            filter: drop-shadow(0 0 15px rgba(114, 137, 218, 0.6));
        }

        .discord-box p {
            color: var(--text-gray);
            margin-bottom: 35px;
        }

        .btn-discord { background: #7289DA; box-shadow: 0 0 15px rgba(114, 137, 218, 0.4); }
        .btn-discord:hover { background: #5b73c7; box-shadow: 0 0 25px #7289DA; }

        /* --- RODAPÉ --- */
        footer {
            background-color: #050505;
            border-top: 1px solid var(--border-glass);
            padding: 40px 0;
            text-align: center;
        }

        footer .logo-footer { font-size: 1.8rem; font-weight: 800; letter-spacing: 2px; }
        footer .logo-footer span { color: var(--primary); }
        footer p { color: var(--text-gray); font-size: 0.85rem; margin-top: 10px; }

        /* --- VOLTAR AO TOPO --- */
        .back-to-top {
            position: fixed;
            bottom: 30px;
            right: -60px;
            width: 45px;
            height: 45px;
            background-color: var(--primary);
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            display: flex;
            justify-content: center;
            align-items: center;
            font-size: 1.2rem;
            z-index: 99;
            transition: all 0.4s ease;
        }

        .back-to-top.show { right: 30px; }

        /* --- RESPONSIVIDADE --- */
        @media (max-width: 768px) {
            .hero-layout h1 { font-size: 2.8rem; }
            .unavailable-grid, .channels-container { grid-template-columns: 1fr; }
            .menu-toggle { display: flex; }
            .nav-menu {
                position: fixed;
                top: 75px; left: -100%; width: 100%; height: calc(100vh - 75px);
                background: rgba(10, 10, 10, 0.98); backdrop-filter: blur(15px);
                flex-direction: column; padding-top: 40px; gap: 30px; transition: 0.4s ease;
            }
            .nav-menu.active { left: 0; }
            .menu-toggle.active span:nth-child(1) { transform: rotate(45deg) translate(6px, 6px); }
            .menu-toggle.active span:nth-child(2) { opacity: 0; }
            .menu-toggle.active span:nth-child(3) { transform: rotate(-45deg) translate(5px, -5px); }
        }
    </style>
</head>
